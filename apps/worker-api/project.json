{
  "name": "worker-api",
  "projectType": "application",
  "sourceRoot": "apps/worker-api/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "main": "apps/worker-api/src/index.ts",
        "outputPath": "dist/apps/worker-api",
        "tsConfig": "apps/worker-api/tsconfig.app.json",
        "esbuildOptions": {
          "bundle": true,
          "format": "esm",
          "platform": "neutral",
          "target": "es2022",
          "alias": {
            "@org/core": "/home/dfox/ai/cloudflare-mono-repo/packages/core/src/index.ts",
            "@org/tenant-mrrainbowsmoke": "/home/dfox/ai/cloudflare-mono-repo/tenants/mrrainbowsmoke/index.ts",
            "@org/tenant-rainbowsmokeofficial": "/home/dfox/ai/cloudflare-mono-repo/tenants/rainbowsmokeofficial/index.ts"
          }
        }
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "apps/worker-api/vitest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/worker-api/**/*.ts"]
      }
    }
  },
  "tags": []
}
