{
  "name": "worker-api",
  "projectType": "application",
  "sourceRoot": "apps/worker-api/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "main": "apps/worker-api/src/index.ts",
        "outputPath": "dist/apps/worker-api",
        "tsConfig": "apps/worker-api/tsconfig.app.json",
        "esbuildOptions": {
          "bundle": true,
          "format": "esm",
          "platform": "neutral",
          "target": "es2022"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash -lc \"unset NX_TERMINAL_CAPTURE_STDERR; npx vitest --run --config apps/worker-api/vitest.config.ts\"",
        "forwardAllArgs": false,
        "env": {
          "CI": "false"
        },
        "usePty": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/worker-api/**/*.ts"]
      }
    }
  },
  "tags": []
}
