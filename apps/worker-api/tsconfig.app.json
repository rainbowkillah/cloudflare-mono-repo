{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/apps/worker-api",
    "types": ["@cloudflare/workers-types"],
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "../../packages/core/src/**/*.ts",
