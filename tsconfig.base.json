{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "paths": {
      "@org/core": ["./packages/core/dist/index.d.ts"],
      "@org/testing": ["./packages/testing/dist/index.d.ts"],
      "@org/tenant-mrrainbowsmoke": ["./tenants/mrrainbowsmoke/dist/index.d.ts"],
      "@org/tenant-rainbowsmokeofficial": [
        "./tenants/rainbowsmokeofficial/dist/index.d.ts"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"]
  }
}
